---
import fa from "../i18n/fa.json";
import Icon from "./Icon.astro";

const socials = [
  { name: "github", href: "https://github.com/pourmirzai", label: "GitHub" },
  { name: "linkedin", href: "https://linkedin.com/in/pourmirzai", label: "LinkedIn" },
  { name: "instagram", href: "https://instagram.com/pourmirzai", label: "Instagram" },
  { name: "telegram", href: "https://t.me/pourmirzai", label: "Telegram" },
  { name: "x", href: "https://x.com/pourmirzai", label: "X" },
];
---

<section id="contact" class="section-pad relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(60%_60%_at_50%_100%,rgba(100,255,218,0.07),transparent_70%)]"></div>
  <div class="container-px relative">
    <div class="mx-auto max-w-2xl text-center">
      <p data-reveal class="eyebrow justify-center">
        <Icon name="mail" size={14} />
        <span data-i18n="contact.eyebrow">{fa.contact.eyebrow}</span>
      </p>
      <h2 data-reveal data-i18n="contact.title" class="heading-lg">{fa.contact.title}</h2>
      <p data-reveal data-i18n="contact.subtitle" class="mx-auto mt-4 text-muted">{fa.contact.subtitle}</p>
    </div>

    <div class="mx-auto mt-12 grid max-w-5xl gap-8 lg:grid-cols-[1.4fr_1fr]">
      <!-- Form -->
      <form
        data-reveal
        id="contact-form"
        class="rounded-3xl border border-white/5 bg-surface/60 p-6 sm:p-8"
        action="https://formspree.io/f/your-form-id"
        method="POST"
      >
        <div class="grid gap-5 sm:grid-cols-2">
          <div class="sm:col-span-1">
            <label for="name" data-i18n="contact.formName" class="mb-2 block text-sm font-medium text-text/90">{fa.contact.formName}</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              data-i18n-ph="contact.formNamePh"
              placeholder={fa.contact.formNamePh}
              class="w-full rounded-xl border border-white/10 bg-bg/60 px-4 py-3 text-sm text-text outline-none transition-colors placeholder:text-muted/60 focus:border-tech-cyan/60 focus:ring-2 focus:ring-tech-cyan/20"
            />
          </div>
          <div class="sm:col-span-1">
            <label for="email" data-i18n="contact.formEmail" class="mb-2 block text-sm font-medium text-text/90">{fa.contact.formEmail}</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              data-i18n-ph="contact.formEmailPh"
              placeholder={fa.contact.formEmailPh}
              class="w-full rounded-xl border border-white/10 bg-bg/60 px-4 py-3 text-sm text-text outline-none transition-colors placeholder:text-muted/60 focus:border-tech-cyan/60 focus:ring-2 focus:ring-tech-cyan/20"
            />
          </div>
        </div>

        <div class="mt-5">
          <label for="subject" data-i18n="contact.formSubject" class="mb-2 block text-sm font-medium text-text/90">{fa.contact.formSubject}</label>
          <select
            id="subject"
            name="subject"
            data-i18n-list="subjects"
            class="w-full rounded-xl border border-white/10 bg-bg/60 px-4 py-3 text-sm text-text outline-none transition-colors focus:border-tech-cyan/60 focus:ring-2 focus:ring-tech-cyan/20"
          >
            {
              fa.contact.subjects.map((s, i) => (
                <option value={i} selected={i === 0}>{s}</option>
              ))
            }
          </select>
        </div>

        <div class="mt-5">
          <label for="message" data-i18n="contact.formMessage" class="mb-2 block text-sm font-medium text-text/90">{fa.contact.formMessage}</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            data-i18n-ph="contact.formMessagePh"
            placeholder={fa.contact.formMessagePh}
            class="w-full resize-none rounded-xl border border-white/10 bg-bg/60 px-4 py-3 text-sm text-text outline-none transition-colors placeholder:text-muted/60 focus:border-tech-cyan/60 focus:ring-2 focus:ring-tech-cyan/20"
          ></textarea>
        </div>

        <button type="submit" class="btn btn-primary mt-6 w-full sm:w-auto">
          <span data-i18n="contact.submit">{fa.contact.submit}</span>
          <Icon name="external" size={16} />
        </button>

        <p id="form-status" class="mt-4 hidden text-sm text-tech-cyan"></p>
      </form>

      <!-- Side info -->
      <aside data-reveal class="flex flex-col gap-6">
        <div class="rounded-3xl border border-white/5 bg-surface/60 p-6">
          <h3 class="flex items-center gap-2 font-mono text-xs uppercase tracking-[0.2em] text-tech-cyan">
            <Icon name="mail" size={14} />
            <span data-i18n="contact.emailLabel">{fa.contact.emailLabel}</span>
          </h3>
          <a
            id="email-link"
            href="#"
            class="mt-3 inline-block font-mono text-sm text-text transition-colors hover:text-tech-cyan"
            >info [at] sarvinwildlife [dot] com</a
          >
        </div>

        <div class="rounded-3xl border border-white/5 bg-surface/60 p-6">
          <h3 class="flex items-center gap-2 font-mono text-xs uppercase tracking-[0.2em] text-nature-gold-bright">
            <Icon name="leaf" size={14} />
            <span data-i18n="contact.locationLabel">{fa.contact.locationLabel}</span>
          </h3>
          <!-- mini map pin -->
          <div class="relative mt-4 grid h-28 place-items-center overflow-hidden rounded-xl bg-gradient-to-br from-nature-deep/40 to-tech-navy/40">
            <span class="absolute h-3 w-3 animate-pulse-dot rounded-full bg-nature-gold-bright"></span>
            <span class="absolute h-3 w-3 rounded-full bg-nature-gold-bright/40"></span>
            <span class="absolute bottom-3 font-mono text-[10px] uppercase tracking-widest text-muted">35.6892° N · 51.3890° E</span>
          </div>
        </div>

        <div class="rounded-3xl border border-white/5 bg-surface/60 p-6">
          <div class="flex flex-wrap gap-3">
            {
              socials.map((s) => (
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={s.label}
                  class="grid h-11 w-11 place-items-center rounded-xl border border-white/10 text-muted transition-all hover:-translate-y-0.5 hover:border-tech-cyan hover:text-tech-cyan"
                >
                  <Icon name={s.name} size={18} />
                </a>
              ))
            }
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
  // Email de-obfuscation + form handling (kept inline & framework-free)
  const link = document.getElementById("email-link");
  if (link) {
    const reveal = () => {
      link.textContent = "info@sarvinwildlife.com";
      link.setAttribute("href", "mailto:info@sarvinwildlife.com");
    };
    link.addEventListener("click", (e) => {
      e.preventDefault();
      reveal();
    });
    link.addEventListener("mouseenter", reveal, { once: true });
  }

  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status");
  form?.addEventListener("submit", async (e) => {
    if (!form.action || form.action.includes("your-form-id")) {
      e.preventDefault();
      if (status) {
        status.textContent = form.dataset.demo || "⚠️ Connect a form backend (Formspree/Resend) to enable sending.";
        status.classList.remove("hidden");
      }
      return;
    }
    e.preventDefault();
    try {
      const res = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      });
      if (res.ok) {
        form.reset();
        if (status) status.textContent = "✓";
        status?.classList.remove("hidden");
      }
    } catch {
      /* noop */
    }
  });
</script>
