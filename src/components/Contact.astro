---
import fa from "../i18n/fa.json";
import Icon from "./Icon.astro";

const socials = [
  { name: "github", href: "https://github.com/pourmirzai", label: "GitHub" },
  { name: "linkedin", href: "https://linkedin.com/in/pourmirzai", label: "LinkedIn" },
  { name: "instagram", href: "https://instagram.com/pourmirzai", label: "Instagram" },
  { name: "telegram", href: "https://t.me/pourmirzai", label: "Telegram" },
  { name: "x", href: "https://x.com/pourmirzai", label: "X" },
];
---

<section id="contact" class="section-pad relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(60%_60%_at_50%_100%,rgba(100,255,218,0.07),transparent_70%)]"></div>
  <div class="container-px relative">
    <div class="mx-auto max-w-2xl text-center">
      <p data-reveal class="eyebrow justify-center">
        <Icon name="mail" size={14} />
        <span data-i18n="contact.eyebrow">{fa.contact.eyebrow}</span>
      </p>
      <h2 data-reveal data-i18n="contact.title" class="heading-lg">{fa.contact.title}</h2>
      <p data-reveal data-i18n="contact.subtitle" class="mx-auto mt-4 text-muted">{fa.contact.subtitle}</p>
    </div>

    <div class="mx-auto mt-12 grid max-w-4xl gap-6 sm:grid-cols-2">
      <!-- Email (masked) -->
      <div data-reveal class="card flex flex-col items-center justify-center gap-3 p-8 text-center">
        <span class="grid h-12 w-12 place-items-center rounded-full bg-tech-cyan/10 text-tech-cyan">
          <Icon name="mail" size={22} />
        </span>
        <h3 data-i18n="contact.emailLabel" class="font-mono text-xs uppercase tracking-[0.25em] text-muted">
          {fa.contact.emailLabel}
        </h3>
        <a
          id="email-link"
          href="#"
          class="font-mono text-base text-text transition-colors hover:text-tech-cyan"
        >
          info [at] sarvinwildlife [dot] com
        </a>
        <span data-i18n="contact.emailHint" class="text-xs text-muted/70">{fa.contact.emailHint}</span>
      </div>

      <!-- Socials -->
      <div data-reveal class="card flex flex-col items-center justify-center gap-4 p-8 text-center">
        <span class="grid h-12 w-12 place-items-center rounded-full bg-nature-gold-bright/10 text-nature-gold-bright">
          <Icon name="sparkle" size={22} />
        </span>
        <h3 data-i18n="contact.socialsLabel" class="font-mono text-xs uppercase tracking-[0.25em] text-muted">
          {fa.contact.socialsLabel}
        </h3>
        <div class="flex flex-wrap items-center justify-center gap-3">
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.label}
                class="grid h-12 w-12 place-items-center rounded-xl border border-white/10 text-muted transition-all hover:-translate-y-0.5 hover:border-tech-cyan hover:text-tech-cyan"
              >
                <Icon name={s.name} size={20} />
              </a>
            ))
          }
        </div>
        <span data-i18n="contact.locationLabel" class="text-xs text-muted/70">{fa.contact.locationLabel}</span>
      </div>
    </div>
  </div>
</section>

<script>
  // Email de-obfuscation: reveal the real address on click/hover (spam-safe).
  const link = document.getElementById("email-link");
  if (link) {
    const reveal = () => {
      link.textContent = "info@sarvinwildlife.com";
      link.setAttribute("href", "mailto:info@sarvinwildlife.com");
    };
    link.addEventListener("click", (e) => {
      e.preventDefault();
      reveal();
    });
    link.addEventListener("mouseenter", reveal, { once: true });
    link.addEventListener("focus", reveal, { once: true });
  }
</script>
