---
import fa from "../i18n/fa.json";
import Icon from "./Icon.astro";
---

<section id="press" class="section-pad relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(80%_60%_at_50%_0%,rgba(199,154,58,0.07),transparent_70%)]"></div>
  <div class="container-px relative">
    <div class="mx-auto max-w-2xl text-center">
      <p data-reveal class="eyebrow justify-center">
        <Icon name="sparkle" size={14} />
        <span data-i18n="press.eyebrow">{fa.press.eyebrow}</span>
      </p>
      <h2 data-reveal data-i18n="press.title" class="heading-lg">{fa.press.title}</h2>
      <p data-reveal data-i18n="press.subtitle" class="mx-auto mt-4 text-muted">{fa.press.subtitle}</p>
    </div>

    <!-- Monochrome, linked media outlets (data-driven) -->
    <div
      data-i18n-list="press"
      class="mt-12 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6"
    >
      {
        fa.press.outlets.map((o) => (
          <a
            href={o.url || "#"}
            target={o.url && o.url !== "#" ? "_blank" : undefined}
            rel={o.url && o.url !== "#" ? "noopener noreferrer" : undefined}
            class="press-logo card card-hover group flex h-28 items-center justify-center text-center"
            data-reveal
          >
            <span class="font-mono text-lg font-semibold tracking-tight text-muted transition-colors group-hover:text-text">
              {o.name}
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
