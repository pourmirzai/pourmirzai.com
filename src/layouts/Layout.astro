---
import "../styles/global.css";

// Fonts (self-hosted via Fontsource)
import "@fontsource/vazirmatn/400.css";
import "@fontsource/vazirmatn/500.css";
import "@fontsource/vazirmatn/700.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";

import fa from "../i18n/fa.json";
import Icon from "../components/Icon.astro";
import { Image } from "astro:assets";
import portrait from "../assets/morteza-portrait.jpg";

interface Props {
  title?: string;
  description?: string;
}
const { title = fa.meta.title, description = fa.meta.description } = Astro.props;

const nav = [
  { href: "#about", key: "nav.about", label: fa.nav.about },
  { href: "#worlds", key: "nav.worlds", label: fa.nav.worlds },
  { href: "#press", key: "nav.press", label: fa.nav.press },
  { href: "#contact", key: "nav.contact", label: fa.nav.contact },
];

const socials = [
  { name: "github", href: "https://github.com/pourmirzai", label: "GitHub" },
  { name: "linkedin", href: "https://linkedin.com/in/pourmirzai", label: "LinkedIn" },
  { name: "instagram", href: "https://instagram.com/pourmirzai", label: "Instagram" },
  { name: "telegram", href: "https://t.me/pourmirzai", label: "Telegram" },
  { name: "x", href: "https://x.com/pourmirzai", label: "X" },
];
---

<!doctype html>
<html lang="fa" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Morteza Pourmirzai" />
    <meta name="theme-color" content="#0D0D0D" />
    <link rel="canonical" href="https://pourmirzai.com" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://pourmirzai.com" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://pourmirzai.com/og.svg" />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:locale:alternate" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://pourmirzai.com/og.svg" />

    <!-- Preconnects (Fontsource local, but keep for any remote) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />

    <!-- Set lang/dir + js-ready BEFORE paint to avoid RTL/text flash.
         Failsafe: if the app script never boots, force-reveal content. -->
    <script is:inline>
      (function () {
        try {
          var l = localStorage.getItem("lang");
          var el = document.documentElement;
          if (l === "en") {
            el.lang = "en";
            el.dir = "ltr";
          } else {
            el.lang = "fa";
            el.dir = "rtl";
          }
          el.classList.add("js-ready");
        } catch (e) {
          document.documentElement.classList.add("js-ready");
        }
        window.addEventListener("load", function () {
          setTimeout(function () {
            if (!window.__APP_BOOTED__) {
              document.documentElement.classList.add("reveal-safe");
            }
          }, 2500);
        });
      })();
    </script>
  </head>

  <body>
    <!-- Skip link -->
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-tech-cyan focus:px-4 focus:py-2 focus:text-tech-navy"
    >
      Skip to content
    </a>

    <!-- Scroll progress -->
    <div
      id="scroll-progress"
      class="fixed inset-x-0 top-0 z-[60] h-0.5 origin-left scale-x-0 bg-gradient-to-r from-nature-gold-bright to-tech-cyan"
    >
    </div>

    <!-- ===== HEADER ===== -->
    <header
      id="site-header"
      class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
    >
      <div class="container-px">
        <nav
          class="mt-3 flex items-center justify-between rounded-full border border-white/5 glass px-4 py-2.5 md:px-6"
          aria-label="Primary"
        >
          <!-- Brand: avatar + name -->
          <a href="#hero" class="group flex items-center gap-2.5 rounded-full" aria-label="Morteza Pourmirzai — home">
            <span class="hero-avatar shrink-0">
              <Image
                src={portrait}
                alt="Morteza Pourmirzai"
                width={80}
                height={80}
                densities={[1, 2]}
                loading="eager"
                decoding="async"
              />
            </span>
            <span class="font-mono text-sm font-semibold tracking-tight text-text transition-colors group-hover:text-tech-cyan">
              <span data-i18n="hero.name">{fa.hero.name}</span>
            </span>
          </a>

          <!-- Desktop nav -->
          <ul class="hidden items-center gap-1.5 md:flex">
            {
              nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    data-nav-link={item.href}
                    class="nav-link relative rounded-full px-4 py-2 text-sm text-muted transition-colors duration-300 hover:text-tech-cyan focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-tech-cyan/60 focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
                  >
                    <span class="relative z-10" data-i18n={item.key}>{item.label}</span>
                    <span class="nav-underline absolute inset-x-3.5 -bottom-0.5 h-px origin-center scale-x-0 bg-tech-cyan/70 transition-transform duration-300" />
                  </a>
                </li>
              ))
            }
          </ul>

          <!-- Right cluster -->
          <div class="flex items-center gap-2">
            <!-- Language toggle -->
            <button
              id="lang-toggle"
              type="button"
              class="flex items-center gap-1.5 rounded-full border border-white/10 px-3 py-1.5 font-mono text-xs text-muted transition-colors hover:border-tech-cyan hover:text-tech-cyan focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-tech-cyan/60"
              aria-label="Toggle language"
            >
              <span class="text-tech-cyan">◍</span>
              <span data-i18n="meta.langSwitch">{fa.meta.langSwitch}</span>
            </button>

            <!-- Mobile menu button -->
            <button
              id="menu-toggle"
              type="button"
              class="grid h-9 w-9 place-items-center rounded-full border border-white/10 text-muted transition-colors hover:border-tech-cyan hover:text-tech-cyan focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-tech-cyan/60 md:hidden"
              aria-label="Open menu"
              aria-expanded="false"
            >
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M4 7h16M4 12h16M4 17h16"></path>
              </svg>
            </button>
          </div>
        </nav>

        <!-- Mobile menu -->
        <div
          id="mobile-menu"
          class="mt-2 hidden origin-top flex-col gap-1 rounded-2xl border border-white/5 glass p-3 md:hidden"
        >
          {
            nav.map((item) => (
              <a
                href={item.href}
                data-i18n={item.key}
                data-nav-link={item.href}
                class="mobile-link rounded-xl px-4 py-3 text-sm text-muted transition-colors hover:bg-white/5 hover:text-tech-cyan focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-tech-cyan/60"
              >
                {item.label}
              </a>
            ))
          }
        </div>
      </div>
    </header>

    <!-- ===== MAIN ===== -->
    <main id="main">
      <slot />
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="relative border-t border-white/5 py-12">
      <div class="container-px">
        <div class="flex flex-col items-center justify-between gap-8 md:flex-row">
          <div class="text-center md:text-start">
            <p class="font-mono text-sm font-semibold text-text">
              Morteza Pourmirzai
            </p>
            <p data-i18n="footer.tagline" class="mt-1 text-sm text-muted">
              {fa.footer.tagline}
            </p>
          </div>

          <div class="flex items-center gap-3">
            {
              socials.map((s) => (
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={s.label}
                  class="grid h-10 w-10 place-items-center rounded-full border border-white/10 text-muted transition-all hover:-translate-y-0.5 hover:border-tech-cyan hover:text-tech-cyan"
                >
                  <Icon name={s.name} size={18} />
                </a>
              ))
            }
          </div>
        </div>

        <div class="mt-8 flex flex-col items-center justify-between gap-2 border-t border-white/5 pt-6 text-xs text-muted sm:flex-row">
          <p>© <span id="year">2026</span> Morteza Pourmirzai. <span data-i18n="footer.rights">{fa.footer.rights}</span></p>
          <p data-i18n="footer.madeWith" class="font-mono">{fa.footer.madeWith}</p>
        </div>
      </div>
    </footer>

    <!-- ===== SCRIPTS ===== -->
    <script>
      import "@/scripts/i18n";
      import "@/scripts/main";
    </script>
  </body>
</html>
