---
import "../styles/global.css";

// Fonts (self-hosted via Fontsource)
import "@fontsource/vazirmatn/400.css";
import "@fontsource/vazirmatn/500.css";
import "@fontsource/vazirmatn/700.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";

import fa from "../i18n/fa.json";
import Icon from "../components/Icon.astro";

interface Props {
  title?: string;
  description?: string;
}
const { title = fa.meta.title, description = fa.meta.description } = Astro.props;

const nav = [
  { href: "#about", key: "nav.about", label: fa.nav.about },
  { href: "#worlds", key: "nav.worlds", label: fa.nav.worlds },
  { href: "#work", key: "nav.work", label: fa.nav.work },
  { href: "#press", key: "nav.press", label: fa.nav.press },
  { href: "#contact", key: "nav.contact", label: fa.nav.contact },
];

const socials = [
  { name: "github", href: "https://github.com/pourmirzai", label: "GitHub" },
  { name: "linkedin", href: "https://linkedin.com/in/pourmirzai", label: "LinkedIn" },
  { name: "instagram", href: "https://instagram.com/pourmirzai", label: "Instagram" },
  { name: "telegram", href: "https://t.me/pourmirzai", label: "Telegram" },
  { name: "x", href: "https://x.com/pourmirzai", label: "X" },
];
---

<!doctype html>
<html lang="fa" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Morteza Pourmirzai" />
    <meta name="theme-color" content="#0D0D0D" />
    <link rel="canonical" href="https://pourmirzai.com" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://pourmirzai.com" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://pourmirzai.com/og.svg" />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:locale:alternate" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://pourmirzai.com/og.svg" />

    <!-- Preconnects (Fontsource local, but keep for any remote) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />

    <!-- Set lang/dir + js-ready BEFORE paint to avoid RTL/text flash -->
    <script is:inline>
      (function () {
        try {
          var l = localStorage.getItem("lang");
          var el = document.documentElement;
          if (l === "en") {
            el.lang = "en";
            el.dir = "ltr";
          } else {
            el.lang = "fa";
            el.dir = "rtl";
          }
          el.classList.add("js-ready");
        } catch (e) {
          document.documentElement.classList.add("js-ready");
        }
      })();
    </script>
  </head>

  <body>
    <!-- Skip link -->
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-tech-cyan focus:px-4 focus:py-2 focus:text-tech-navy"
    >
      Skip to content
    </a>

    <!-- Scroll progress -->
    <div
      id="scroll-progress"
      class="fixed inset-x-0 top-0 z-[60] h-0.5 origin-left scale-x-0 bg-gradient-to-r from-nature-gold-bright to-tech-cyan"
    >
    </div>

    <!-- ===== HEADER ===== -->
    <header
      id="site-header"
      class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
    >
      <div class="container-px">
        <nav
          class="mt-3 flex items-center justify-between rounded-full border border-white/5 glass px-4 py-2.5 md:px-6"
          aria-label="Primary"
        >
          <!-- Logo -->
          <a href="#hero" class="group flex items-center gap-2.5" aria-label="Home">
            <span
              class="relative grid h-9 w-9 place-items-center rounded-full bg-gradient-to-br from-nature-gold-bright to-nature-deep"
            >
              <svg viewBox="0 0 24 24" class="h-5 w-5 text-bg" fill="currentColor" aria-hidden="true">
                <path
                  d="M8.5 4c.6 0 1 .7 1 1.6S9.1 7.2 8.5 7.2s-1-.7-1-1.6S7.9 4 8.5 4Zm7 0c.6 0 1 .7 1 1.6s-.4 1.6-1 1.6-1-.7-1-1.6.4-1.6 1-1.6ZM12 2c.7 0 1.2.8 1.2 1.8S12.7 5.6 12 5.6s-1.2-.8-1.2-1.8S11.3 2 12 2ZM5.5 7C6.3 7 7 7.9 7 9s-.7 2-1.5 2S4 10.1 4 9s.7-2 1.5-2Zm13 0c.8 0 1.5.9 1.5 2s-.7 2-1.5 2-1.5-.9-1.5-2 .7-2 1.5-2ZM12 7c2.8 0 5 2.4 5 5.3 0 2.2-1.3 3.4-2.4 4.4-.7.6-1.3 1.2-1.6 2-.3.9-1 1.3-1 2.3 0 .9-.7 1-1 .3-.6-1.5.2-2.7.9-3.7.5-.7 1-1.3 1-2.1 0-1-.7-1.5-1.4-1.5-.5 0-.9.2-1.2.6-.4.5-.9.6-1.3.3-.5-.4-.3-1 .1-1.6.5-.7 1-1.4 1-2.4 0-1.2-.8-2-2-2-.7 0-1.2.3-1.6.7-.4.4-.9.5-1.3.1-.5-.5-.2-1.2.3-1.7C8.2 7.9 9.9 7 12 7Z"
                ></path>
              </svg>
            </span>
            <span class="font-mono text-sm font-semibold tracking-tight">
              <span class="text-text">MP</span><span class="text-tech-cyan">.</span>
            </span>
          </a>

          <!-- Desktop nav -->
          <ul class="hidden items-center gap-1 md:flex">
            {
              nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    data-i18n={item.key}
                    class="rounded-full px-3.5 py-2 text-sm text-muted transition-colors hover:text-tech-cyan"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>

          <!-- Right cluster -->
          <div class="flex items-center gap-2">
            <!-- Language toggle -->
            <button
              id="lang-toggle"
              type="button"
              class="flex items-center gap-1.5 rounded-full border border-white/10 px-3 py-1.5 font-mono text-xs text-muted transition-colors hover:border-tech-cyan hover:text-tech-cyan"
              aria-label="Toggle language"
            >
              <span class="text-tech-cyan">◍</span>
              <span data-i18n="meta.langSwitch">{fa.meta.langSwitch}</span>
            </button>

            <!-- Mobile menu button -->
            <button
              id="menu-toggle"
              type="button"
              class="grid h-9 w-9 place-items-center rounded-full border border-white/10 text-muted md:hidden"
              aria-label="Open menu"
              aria-expanded="false"
            >
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M4 7h16M4 12h16M4 17h16"></path>
              </svg>
            </button>
          </div>
        </nav>

        <!-- Mobile menu -->
        <div
          id="mobile-menu"
          class="mt-2 hidden origin-top flex-col gap-1 rounded-2xl border border-white/5 glass p-3 md:hidden"
        >
          {
            nav.map((item) => (
              <a
                href={item.href}
                data-i18n={item.key}
                class="mobile-link rounded-xl px-4 py-3 text-sm text-muted transition-colors hover:bg-white/5 hover:text-tech-cyan"
              >
                {item.label}
              </a>
            ))
          }
        </div>
      </div>
    </header>

    <!-- ===== MAIN ===== -->
    <main id="main">
      <slot />
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="relative border-t border-white/5 py-12">
      <div class="container-px">
        <div class="flex flex-col items-center justify-between gap-8 md:flex-row">
          <div class="text-center md:text-start">
            <p class="font-mono text-sm font-semibold text-text">
              Morteza Pourmirzai
            </p>
            <p data-i18n="footer.tagline" class="mt-1 text-sm text-muted">
              {fa.footer.tagline}
            </p>
          </div>

          <div class="flex items-center gap-3">
            {
              socials.map((s) => (
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={s.label}
                  class="grid h-10 w-10 place-items-center rounded-full border border-white/10 text-muted transition-all hover:-translate-y-0.5 hover:border-tech-cyan hover:text-tech-cyan"
                >
                  <Icon name={s.name} size={18} />
                </a>
              ))
            }
          </div>
        </div>

        <div class="mt-8 flex flex-col items-center justify-between gap-2 border-t border-white/5 pt-6 text-xs text-muted sm:flex-row">
          <p>© <span id="year">2026</span> Morteza Pourmirzai. <span data-i18n="footer.rights">{fa.footer.rights}</span></p>
          <p data-i18n="footer.madeWith" class="font-mono">{fa.footer.madeWith}</p>
        </div>
      </div>
    </footer>

    <!-- ===== SCRIPTS ===== -->
    <script>
      import "@/scripts/i18n";
      import "@/scripts/main";
    </script>
  </body>
</html>
